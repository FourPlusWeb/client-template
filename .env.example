# Required: GitHub Packages access for installing @fourplusweb/* packages.
# Classic Personal Access Token with scope: read:packages only.
# Provisioned per ACCESS.md in workspace root.
NODE_AUTH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Sentry DSN (if siteConfig.monitoring.sentry configured).
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# Optional: site URL override (defaults to siteConfig.url).
# NEXT_PUBLIC_SITE_URL=https://acme-plumbing.bg
