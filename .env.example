# Required: GitHub Packages access for installing @fourplusweb/* packages.
# Classic Personal Access Token with scope: read:packages only.
# Provisioned per ACCESS.md in workspace root.
NODE_AUTH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry — dual-DSN model (W6.4). Priority: client-specific > studio default.
# Events tagged with siteName + studioFleet:fourplusweb so the studio project
# can filter per-site. Leave both unset → Sentry is a no-op.
#
# Client-specific override. Uncomment + set when a client runs their own
# Sentry project (e.g. future enterprise). Leave blank to use studio default.
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXXXX.ingest.sentry.io/YYYY
#
# FourPlus Studio fallback. Pre-filled at Netlify deployment level by studio
# staff (or by @fourplusweb/create-site on scaffold). Do not delete — every
# client site should report somewhere. See ACCESS.md §Sentry.
# NEXT_PUBLIC_SENTRY_DSN_STUDIO_DEFAULT=https://xxx@oXXXXX.ingest.sentry.io/YYYY

# Optional: site URL override (defaults to siteConfig.url).
# NEXT_PUBLIC_SITE_URL=https://acme-plumbing.bg

# Required in production: Resend API key for contact form email delivery.
# Free tier at https://resend.com/signup (3000 emails/month).
# In local dev, submissions log to the console without sending if absent.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the recipient address for contact-form notifications.
# Defaults to siteConfig.contact.email.
# RESEND_NOTIFY_EMAIL=hello@example.com

# Optional: sender address for contact-form notifications.
# Defaults to noreply@<siteConfig.url host>. Domain must be verified in
# the Resend dashboard (SPF + DKIM at client's DNS provider) for
# deliverability.
# RESEND_FROM=contact@example.com

# Upstash Redis — distributed rate-limit for contact form.
# Create a free database at https://upstash.com and copy REST API URL + token.
# If absent, falls back to in-memory rate-limit (resets on cold start).
# UPSTASH_REST_API_URL=https://xxx.upstash.io
# UPSTASH_REST_API_TOKEN=xxx

# hCaptcha — bot challenge for contact form (GDPR-friendlier than Google).
# Optional. If configured in site.config.ts captcha field, form requires
# captcha completion before submission.
# hCaptcha site key (public) → goes in site.config.ts captcha.siteKey
# hCaptcha secret key (private) → goes here as HCAPTCHA_SECRET
# Get keys at https://www.hcaptcha.com/
# HCAPTCHA_SECRET=0x...your-secret

# Studio auth — password gate on /studio/brand routes.
# Optional. If set, studio routes require Basic Auth with this password.
# In production, always use HTTPS to prevent credential interception.
# STUDIO_PASSWORD=your-secure-password
