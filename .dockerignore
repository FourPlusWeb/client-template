# Keep the Docker build context small and deterministic.
node_modules
.next
.turbo
.pnpm-store

# Local env — never bake secrets into images.
.env
.env.local
.env.*.local

# Editor / OS noise
.claude
.vscode
.idea
.DS_Store
Thumbs.db

# Version control
.git
.gitignore

# Testing + coverage artifacts
coverage
playwright-report
test-results

# Docs not needed at runtime (kept in repo but excluded from image)
docs
*.md
!README.md

# Build artifacts and logs
dist
*.log
tsconfig.tsbuildinfo
next-env.d.ts
